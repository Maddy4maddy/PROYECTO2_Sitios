<?xml version="1.0"?>
<configuration>

	<connectionStrings>
		<add
		  name="MySQLConnection"
		  connectionString="Server=zen-greider.138-59-135-33.plesk.page;Port=3306;Database=tiusr2pl_administracion_personal;Uid=PiratasCorazon11;Pwd=12328Piratas;CharSet=utf8mb4;AllowPublicKeyRetrieval=True;"
		  providerName="MySql.Data.MySqlClient"
    />
	</connectionStrings>

	<!--
    Para obtener una descripción de los cambios de web.config, vea:
    http://go.microsoft.com/fwlink/?LinkId=235367
  -->

	<system.web>
		<compilation
		  debug="true"
		  targetFramework="4.8"
    />

		<httpRuntime
		  targetFramework="4.8"
    />
	</system.web>

	<system.serviceModel>

		<behaviors>

			<serviceBehaviors>
				<behavior>
					<serviceMetadata
					  httpGetEnabled="true"
					  httpsGetEnabled="true"
          />

					<serviceDebug
					  includeExceptionDetailInFaults="true"
          />
				</behavior>
			</serviceBehaviors>

			<endpointBehaviors>
				<behavior name="webBehavior">
					<webHttp />
				</behavior>
			</endpointBehaviors>

		</behaviors>

		<services>

			<!-- CORE 1: listado de puestos activos -->
			<service
			  name="PROYECTO2_WEBService.WEBServiceCORE1"
      >
				<endpoint
				  address=""
				  binding="webHttpBinding"
				  contract="PROYECTO2_WEBService.IService1"
				  behaviorConfiguration="webBehavior"
        />
			</service>

			<!-- CORE 3: creación de empleados -->
			<service
			  name="PROYECTO2_WEBService.WEBServiceCORE3"
      >
				<endpoint
				  address=""
				  binding="webHttpBinding"
				  contract="PROYECTO2_WEBService.IWEBServiceCORE3"
				  behaviorConfiguration="webBehavior"
        />
			</service>

			<!-- CORE 4: inicio de sesión -->
			<service
			  name="PROYECTO2_WEBService.WEBSERVICEcore4"
      >
				<endpoint
				  address=""
				  binding="webHttpBinding"
				  contract="PROYECTO2_WEBService.IWEBSERVICEcore4"
				  behaviorConfiguration="webBehavior"
        />
			</service>

			<!-- CORE 6: detalle de puesto por código -->
			<service
			  name="PROYECTO2_WEBService.WEBServiceCORE6"
      >
				<endpoint
				  address=""
				  binding="webHttpBinding"
				  contract="PROYECTO2_WEBService.IWEBServiceCORE6"
				  behaviorConfiguration="webBehavior"
        />
			</service>
			
			<!-- CORE 8: detalle de oferente -->
			<service name="PROYECTO2_WEBService.WEBServiceCORE8">
				<endpoint address=""
						  binding="webHttpBinding"
						  contract="PROYECTO2_WEBService.IWEBServiceCORE8"
						  behaviorConfiguration="webBehavior" />
			</service>

		</services>

		<serviceHostingEnvironment
		  aspNetCompatibilityEnabled="true"
		  multipleSiteBindingsEnabled="true"
    />

	</system.serviceModel>

	<system.webServer>
		<modules runAllManagedModulesForAllRequests="true" />
		<directoryBrowse enabled="true" />

		<!-- CORS - Permite peticiones desde cualquier origen -->
		<httpProtocol>
			<customHeaders>
				<add name="Access-Control-Allow-Origin" value="*" />
				<add name="Access-Control-Allow-Methods" value="GET, POST, OPTIONS, PUT" />
				<add name="Access-Control-Allow-Headers" value="Content-Type, Accept, X-Requested-With" />
			</customHeaders>
		</httpProtocol>

	</system.webServer>
	<runtime>
		<assemblyBinding
		  xmlns="urn:schemas-microsoft-com:asm.v1"
    >

			<dependentAssembly>
				<assemblyIdentity
				  name="System.Runtime.CompilerServices.Unsafe"
				  publicKeyToken="b03f5f7f11d50a3a"
				  culture="neutral"
        />

				<bindingRedirect
				  oldVersion="0.0.0.0-6.0.0.0"
				  newVersion="6.0.0.0"
        />
			</dependentAssembly>

			<dependentAssembly>
				<assemblyIdentity
				  name="System.Memory"
				  publicKeyToken="cc7b13ffcd2ddd51"
				  culture="neutral"
        />

				<bindingRedirect
				  oldVersion="0.0.0.0-4.0.1.2"
				  newVersion="4.0.1.2"
        />
			</dependentAssembly>

		</assemblyBinding>
	</runtime>

</configuration>